{
  "uid": "cbt-overview",
  "title": "CBT Assistant — Overview",
  "tags": ["cbt", "v4"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Triage distribution (cumulative)",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "sum by (level) (cbt_triage_level_total)",
          "legendFormat": "{{level}}",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "mappings": []
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "L0" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          },
          {
            "matcher": { "id": "byName", "options": "L1" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }]
          },
          {
            "matcher": { "id": "byName", "options": "L2" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }]
          },
          {
            "matcher": { "id": "byName", "options": "L3" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }]
          }
        ]
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Pipeline stage latency (p95, last 5m)",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, stage) (rate(cbt_stage_latency_seconds_bucket[5m])))",
          "legendFormat": "{{stage}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Triage decisions per minute",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 7 },
      "targets": [
        {
          "expr": "sum by (level) (rate(cbt_triage_level_total[1m]) * 60)",
          "legendFormat": "{{level}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Hallucination flag rate (10m)",
      "gridPos": { "x": 12, "y": 6, "w": 6, "h": 7 },
      "targets": [
        {
          "expr": "sum(rate(cbt_hallucination_flag_total[10m])) / clamp_min(sum(rate(cbt_triage_level_total[10m])), 1)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.10 },
              { "color": "red", "value": 0.20 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Preflight fail rate (10m)",
      "gridPos": { "x": 18, "y": 6, "w": 6, "h": 7 },
      "targets": [
        {
          "expr": "sum(rate(cbt_preflight_fail_total[10m])) / clamp_min(sum(rate(cbt_triage_level_total[10m])), 1)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.10 },
              { "color": "red", "value": 0.25 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Clinician review decisions per minute",
      "gridPos": { "x": 0, "y": 13, "w": 12, "h": 7 },
      "targets": [
        {
          "expr": "sum by (decision) (rate(cbt_review_decision_total[1m]) * 60)",
          "legendFormat": "{{decision}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Retrieval candidate count distribution",
      "gridPos": { "x": 12, "y": 13, "w": 12, "h": 7 },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (le) (rate(cbt_retrieval_count_bucket[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(cbt_retrieval_count_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Triage cache hit rate (10m)",
      "gridPos": { "x": 0, "y": 20, "w": 8, "h": 5 },
      "targets": [
        {
          "expr": "sum(rate(cbt_triage_cache_total{outcome=\"hit\"}[10m])) / clamp_min(sum(rate(cbt_triage_cache_total[10m])), 1)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.10 },
              { "color": "green", "value": 0.30 }
            ]
          }
        }
      }
    },
    {
      "id": 9,
      "type": "stat",
      "title": "LLM p95 latency (5m)",
      "gridPos": { "x": 8, "y": 20, "w": 8, "h": 5 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(cbt_stage_latency_seconds_bucket{stage=\"llm_generate\"}[5m])))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 15 }
            ]
          }
        }
      }
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Retrieval p95 latency (5m)",
      "gridPos": { "x": 16, "y": 20, "w": 8, "h": 5 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(cbt_stage_latency_seconds_bucket{stage=\"retrieval\"}[5m])))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        }
      }
    }
  ]
}
