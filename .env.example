# Copy file này thành .env rồi điền giá trị thực

# HuggingFace token (cần để download models khi deploy Modal)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Mock mode (true = không cần GPU, dùng để dev local)
MOCK_LLM=true

# Modal endpoints (điền sau khi deploy modal/llm_service.py)
MODAL_LLM_ENDPOINT=
MODAL_HEALTH_ENDPOINT=
MODAL_SAFETY_ENDPOINT=
MODAL_SAFETY_HEALTH_ENDPOINT=

# Security (để trống sẽ tự tạo khi boot, production nên set cụ thể)
# PHI_AES_KEY_B64=
# JWT_SECRET=
